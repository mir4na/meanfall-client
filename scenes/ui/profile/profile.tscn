[gd_scene load_steps=2 format=3 uid="uid://profile"]

[ext_resource type="Script" path="res://scripts/ui/profile.gd" id="1"]

[node name="Profile" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1")

[node name="Background" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0.04, 0.04, 0.07, 1)

[node name="Margin" type="MarginContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/margin_left = 40
theme_override_constants/margin_top = 40
theme_override_constants/margin_right = 40
theme_override_constants/margin_bottom = 40

[node name="HBox" type="HBoxContainer" parent="Margin"]
layout_mode = 2
theme_override_constants/separation = 40

[node name="StatsPanel" type="PanelContainer" parent="Margin/HBox"]
custom_minimum_size = Vector2(350, 0)
layout_mode = 2

[node name="VBox" type="VBoxContainer" parent="Margin/HBox/StatsPanel"]
layout_mode = 2
theme_override_constants/separation = 15
alignment = 1

[node name="Avatar" type="ColorRect" parent="Margin/HBox/StatsPanel/VBox"]
custom_minimum_size = Vector2(100, 100)
layout_mode = 2
size_flags_horizontal = 4
color = Color(0.2, 0.2, 0.25, 1)

[node name="UsernameLabel" type="Label" parent="Margin/HBox/StatsPanel/VBox"]
layout_mode = 2
theme_override_font_sizes/font_size = 28
text = "Username"
horizontal_alignment = 1

[node name="LeagueLabel" type="Label" parent="Margin/HBox/StatsPanel/VBox"]
layout_mode = 2
theme_override_font_sizes/font_size = 20
theme_override_colors/font_color = Color(0.8, 0.8, 1, 1)
text = "Bronze League"
horizontal_alignment = 1

[node name="HSeparator" type="HSeparator" parent="Margin/HBox/StatsPanel/VBox"]
layout_mode = 2

[node name="Grid" type="GridContainer" parent="Margin/HBox/StatsPanel/VBox"]
layout_mode = 2
size_flags_horizontal = 4
theme_override_constants/h_separation = 20
theme_override_constants/v_separation = 10
columns = 2

[node name="PointsTitle" type="Label" parent="Margin/HBox/StatsPanel/VBox/Grid"]
layout_mode = 2
text = "Total Points:"
theme_override_colors/font_color = Color(0.6, 0.6, 0.6, 1)

[node name="PointsValue" type="Label" parent="Margin/HBox/StatsPanel/VBox/Grid"]
layout_mode = 2
text = "1,000"

[node name="MatchesTitle" type="Label" parent="Margin/HBox/StatsPanel/VBox/Grid"]
layout_mode = 2
text = "Matches Played:"
theme_override_colors/font_color = Color(0.6, 0.6, 0.6, 1)

[node name="MatchesValue" type="Label" parent="Margin/HBox/StatsPanel/VBox/Grid"]
layout_mode = 2
text = "0"

[node name="WinrateTitle" type="Label" parent="Margin/HBox/StatsPanel/VBox/Grid"]
layout_mode = 2
text = "Win Rate:"
theme_override_colors/font_color = Color(0.6, 0.6, 0.6, 1)

[node name="WinrateValue" type="Label" parent="Margin/HBox/StatsPanel/VBox/Grid"]
layout_mode = 2
text = "0%"

[node name="PlaytimeTitle" type="Label" parent="Margin/HBox/StatsPanel/VBox/Grid"]
layout_mode = 2
text = "Total Playtime:"
theme_override_colors/font_color = Color(0.6, 0.6, 0.6, 1)

[node name="PlaytimeValue" type="Label" parent="Margin/HBox/StatsPanel/VBox/Grid"]
layout_mode = 2
text = "0h 0m"

[node name="Spacer" type="Control" parent="Margin/HBox/StatsPanel/VBox"]
custom_minimum_size = Vector2(0, 20)
layout_mode = 2

[node name="LogoutButton" type="Button" parent="Margin/HBox/StatsPanel/VBox"]
custom_minimum_size = Vector2(0, 45)
layout_mode = 2
text = "Logout"

[node name="BackButton" type="Button" parent="Margin/HBox/StatsPanel/VBox"]
custom_minimum_size = Vector2(0, 45)
layout_mode = 2
text = "Back to Menu"

[node name="HistoryPanel" type="PanelContainer" parent="Margin/HBox"]
layout_mode = 2
size_flags_horizontal = 3

[node name="VBox" type="VBoxContainer" parent="Margin/HBox/HistoryPanel"]
layout_mode = 2
theme_override_constants/margin_left = 20
theme_override_constants/margin_top = 20
theme_override_constants/margin_right = 20
theme_override_constants/margin_bottom = 20

[node name="Title" type="Label" parent="Margin/HBox/HistoryPanel/VBox"]
layout_mode = 2
theme_override_font_sizes/font_size = 24
text = "MATCH HISTORY"

[node name="HSeparator" type="HSeparator" parent="Margin/HBox/HistoryPanel/VBox"]
layout_mode = 2

[node name="Scroll" type="ScrollContainer" parent="Margin/HBox/HistoryPanel/VBox"]
layout_mode = 2
size_flags_vertical = 3

[node name="HistoryList" type="VBoxContainer" parent="Margin/HBox/HistoryPanel/VBox/Scroll"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/separation = 10

[node name="LoadingLabel" type="Label" parent="Margin/HBox/HistoryPanel/VBox/Scroll/HistoryList"]
layout_mode = 2
text = "Loading history..."
horizontal_alignment = 1

[connection signal="pressed" from="Margin/HBox/StatsPanel/VBox/LogoutButton" to="." method="_on_logout_pressed"]
[connection signal="pressed" from="Margin/HBox/StatsPanel/VBox/BackButton" to="." method="_on_back_pressed"]
