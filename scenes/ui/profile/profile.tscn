[gd_scene load_steps=2 format=3 uid="uid://profile"]

[ext_resource type="Script" path="res://scripts/ui/profile.gd" id="1"]

[node name="Profile" type="Control"]
layout_mode = 3
anchors_preset = 15
script = ExtResource("1")

[node name="Background" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
color = Color(0.04, 0.04, 0.07, 1)

[node name="Center" type="CenterContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0

[node name="Panel" type="PanelContainer" parent="Center"]
custom_minimum_size = Vector2(480, 420)

[node name="VBox" type="VBoxContainer" parent="Center/Panel"]
theme_override_constants/separation = 18
alignment = 1

[node name="TitleLabel" type="Label" parent="Center/Panel/VBox"]
text = "PROFILE"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 36

[node name="UsernameLabel" type="Label" parent="Center/Panel/VBox"]
text = "..."
horizontal_alignment = 1
theme_override_font_sizes/font_size = 26

[node name="LeagueLabel" type="Label" parent="Center/Panel/VBox"]
text = "League: ..."
horizontal_alignment = 1
theme_override_font_sizes/font_size = 22

[node name="EloLabel" type="Label" parent="Center/Panel/VBox"]
text = "ELO: ..."
horizontal_alignment = 1
theme_override_font_sizes/font_size = 22

[node name="Spacer" type="Control" parent="Center/Panel/VBox"]
