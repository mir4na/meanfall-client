[gd_scene load_steps=2 format=3 uid="uid://profile_section"]

[ext_resource type="Script" path="res://scripts/ui/profile_section.gd" id="1"]

[node name="ProfileSection" type="MarginContainer"]
offset_right = 200.0
offset_bottom = 60.0
theme_override_constants/margin_left = 10
theme_override_constants/margin_top = 10
script = ExtResource("1")

[node name="HBox" type="HBoxContainer" parent="."]
layout_mode = 2
theme_override_constants/separation = 12

[node name="Avatar" type="ColorRect" parent="HBox"]
custom_minimum_size = Vector2(48, 48)
layout_mode = 2
color = Color(0.2, 0.2, 0.25, 1)

[node name="Icon" type="Label" parent="HBox/Avatar"]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
text = "P"
horizontal_alignment = 1
vertical_alignment = 1

[node name="VBox" type="VBoxContainer" parent="HBox"]
layout_mode = 2
alignment = 1

[node name="UsernameLabel" type="Label" parent="HBox/VBox"]
layout_mode = 2
text = "Loading..."
theme_override_font_sizes/font_size = 18

[node name="StatsLabel" type="Label" parent="HBox/VBox"]
layout_mode = 2
text = "0 pts • Bronze"
theme_override_colors/font_color = Color(0.7, 0.7, 0.7, 1)
theme_override_font_sizes/font_size = 14

[node name="Button" type="Button" parent="."]
layout_mode = 2
flat = true

[connection signal="pressed" from="Button" to="." method="_on_pressed"]
